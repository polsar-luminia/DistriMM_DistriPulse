# DistriMM Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# SUPABASE
# Dónde: app.supabase.com → tu proyecto → Settings → API
# =============================================================================
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...   # anon/public key

# =============================================================================
# N8N — Todas las llamadas a n8n van por Supabase Edge Functions.
# Los secretos se configuran en Dashboard → Edge Functions → Secrets:
#   N8N_WHATSAPP_URL=https://tu-n8n.dominio.com/webhook/distrimm-whatsapp
#   N8N_WEBHOOK_URL=https://tu-n8n.dominio.com/webhook/cfo-distrimm
#   N8N_CHAT_URL=https://tu-n8n.dominio.com/webhook/distrimm-chatbot
#   N8N_AUTH_KEY=<misma-cadena-de-arriba>
#   META_APP_ID=<tu Facebook App ID>
#   META_APP_SECRET=<tu Facebook App Secret — NUNCA en frontend>

# =============================================================================
# META CLOUD API — Embedded Signup (WhatsApp Business)
# Con Embedded Signup, cada usuario conecta su propio numero de WhatsApp
# Business. Los datos (phone_number_id, waba_id, phone_display) se guardan
# en la tabla distrimm_whatsapp_instances — ya NO se hardcodean en .env.
# =============================================================================

# APP_ID — Dónde obtenerlo:
#   developers.facebook.com → tu App → Settings → Basic → App ID
#   Es público (seguro en frontend).
VITE_META_APP_ID=TU_META_APP_ID

# CONFIG_ID — Dónde obtenerlo:
#   developers.facebook.com → tu App → Facebook Login for Business → Configurations
#   Crear una configuración con template "WhatsApp Embedded Signup Configuration"
#   y copiar el Configuration ID generado.
VITE_META_CONFIG_ID=TU_META_CONFIG_ID

# SOLUTION_ID (opcional) — Pre-configura opciones durante Embedded Signup.
#   developers.facebook.com → tu App → WhatsApp → Embedded Signup → Solution ID
# VITE_META_SOLUTION_ID=TU_META_SOLUTION_ID

# ─── DEPRECATED (ahora vienen de la DB via Embedded Signup) ───
# VITE_META_PHONE_NUMBER_ID  ← guardado en distrimm_whatsapp_instances
# VITE_META_PHONE_DISPLAY    ← guardado en distrimm_whatsapp_instances
# VITE_META_SANDBOX          ← se maneja por instancia
# VITE_META_WABA_ID          ← guardado en distrimm_whatsapp_instances

# =============================================================================
# META CLOUD API — Solo para n8n (NO son variables VITE_)
# Configúralas directamente en n8n como credenciales o variables de entorno
# del contenedor n8n. NO las pongas en el .env de React.
# =============================================================================

# META_ACCESS_TOKEN — Dónde obtenerlo:
#   1. developers.facebook.com → tu App → WhatsApp → Configuración de API
#   Para pruebas: el token temporal que aparece ahí (expira en 24h)
#   Para producción: crear un "System User" permanente:
#     business.facebook.com → Configuración → Usuarios del sistema
#     → Agregar usuario del sistema → Rol: Empleado o Administrador
#     → Generar token → seleccionar App → permisos: whatsapp_business_messaging,
#       whatsapp_business_management → Generar token (NO expira)
# META_ACCESS_TOKEN=EAAxxxxxxxx...

# META_VERIFY_TOKEN — Dónde obtenerlo:
#   LO CREAS TÚ. Es una contraseña aleatoria que usas para verificar
#   que Meta realmente envía los webhooks (no terceros).
#   Genera uno con: openssl rand -hex 20
#   Ponlo también en Meta for Developers cuando configures el webhook.
# META_VERIFY_TOKEN=tu-string-secreto-aleatorio

# META_GRAPH_API_VERSION — Versión de la API de Meta Graph
#   Usa siempre la más reciente estable. Actualiza cuando Meta lo indique.
# META_GRAPH_API_VERSION=v21.0

# =============================================================================
# SENTRY — Error Tracking (opcional)
# Donde: sentry.io → tu proyecto → Settings → Client Keys (DSN)
# Si no se configura, el tracking de errores queda deshabilitado.
# =============================================================================
# VITE_SENTRY_DSN=https://xxxxx@oXXXX.ingest.sentry.io/YYYYYYY

# =============================================================================
# CHATWOOT
# Dónde: tu instancia Chatwoot → Profile Settings → Access Token
# =============================================================================

# VITE_CHATWOOT_URL — URL pública de tu Chatwoot (sin barra al final)
#   Dónde: es la URL donde instalaste Chatwoot en tu VPS Contabo
VITE_CHATWOOT_URL=https://chat.tudominio.com

# Las siguientes van solo en n8n (son secretos de servidor):

# CHATWOOT_API_TOKEN — Dónde obtenerlo:
#   Chatwoot → Profile Settings (icono de perfil arriba derecha)
#   → Sección "Access Token" al fondo → copiar
# CHATWOOT_API_TOKEN=tu-access-token-de-chatwoot

# CHATWOOT_ACCOUNT_ID — Dónde obtenerlo:
#   Mira la URL de Chatwoot cuando estás logueado:
#   https://chat.tudominio.com/app/accounts/1/...
#   El número después de "accounts/" es tu ACCOUNT_ID
# CHATWOOT_ACCOUNT_ID=1

# CHATWOOT_INBOX_ID — Dónde obtenerlo:
#   Chatwoot → Settings → Inboxes → tu inbox de WhatsApp
#   → Settings → ID aparece en la URL: .../inboxes/5/settings
# CHATWOOT_INBOX_ID=5
